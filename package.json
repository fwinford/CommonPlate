  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/fwinford/CommonPlate/issues"
  },
  "homepage": "https://github.com/fwinford/CommonPlate#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "mongoose": "^8.19.3",
    "helmet": "^7.0.0",
    "node-cron": "^4.2.1",
    "resend": "^6.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.10.0",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.26.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "ts-prune": "^0.8.3",
    "depcheck": "^1.4.2",
    "eslint": "^8.48.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0"
  }
}
