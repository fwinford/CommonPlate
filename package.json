{
  "name": "commonplate",
  "version": "1.0.0",
  "description": "CommonPlate \u2014 a lightweight food request and fulfillment app for campus mutual aid.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:client": "node build-client.mjs",
    "dev": "npm run build:client && tsx watch app.ts",
    "build": "npm run build:client && tsc",
    "start": "node dist/app.js",
    "lint": "eslint --ext .js,.ts src",
    "typecheck": "tsc --noEmit",
    "prune": "ts-prune",
    "depcheck": "depcheck",
    "ci-check": "npm run lint && npm run typecheck && npm run prune && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fwinford/CommonPlate.git"
  },
